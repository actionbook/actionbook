{
  "$schema": "https://unpkg.com/@changesets/config@latest/schema.json",
  "changelog": [
    "@changesets/changelog-github",
    { "repo": "actionbook/actionbook" }
  ],
  "commit": false,
  "fixed": [],
  "linked": [],
  "access": "public",
  "baseBranch": "main",
  "updateInternalDependencies": "patch",
  "privatePackages": {
    "version": true,
    "tag": true
  },
  "ignore": [
    "@actionbookdev/json-ui-site",
    "lib-rs-scraper",
    "stagehand-agent",
    "@actionbookdev/sdk",
    "@actionbookdev/mcp",
    "@actionbookdev/tools-ai-sdk",
    "@actionbookdev/json-ui",
    "@actionbookdev/openclaw-plugin",
    "@actionbookdev/extension",
    "@actionbookdev/dify-plugin"
  ]
}
